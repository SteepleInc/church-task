{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "**/_generated/**",
    "apps/web/src/routeTree.gen.ts",
    "packages/backend-old/**",
    "packages/domain-old/**"
  ],
  "rules": {},
  "overrides": [
    {
      "files": [
        "backend/server/src/**",
        "packages/auth/src/**",
        "packages/db/src/**",
        "packages/domain/src/**",
        "packages/test-harness/src/**",
        "packages/zero/src/**"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@church-task/backend-old",
                "message": "Old backend code is reference-only during the migration; target packages must not import it."
              },
              {
                "name": "@church-task/domain-old",
                "message": "Old domain code is reference-only during the migration; target packages must not import it."
              }
            ],
            "patterns": ["@church-task/backend-old/*", "@church-task/domain-old/*"]
          }
        ]
      }
    },
    {
      "files": ["apps/web/src/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "convex/react",
                "importNames": ["useQuery", "usePaginatedQuery", "useQueries"],
                "message": "Import cache-backed query hooks from @/data/query-hooks instead (ADR 0011); direct convex/react query hooks bypass the query cache."
              },
              {
                "name": "@confect/react",
                "importNames": ["useQuery"],
                "message": "Import useQuery from @/data/query-hooks instead (ADR 0011); @confect/react's useQuery bypasses the query cache."
              },
              {
                "name": "convex-helpers/react/cache",
                "importNames": ["useQuery", "usePaginatedQuery", "useQueries"],
                "message": "Import query hooks from @/data/query-hooks instead (ADR 0011)."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["apps/web/src/data/query-hooks.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "env": {
    "builtin": true
  }
}
